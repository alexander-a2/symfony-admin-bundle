{% extends '@Admin/layout/dashboard.html.twig' %}

{% block main %}
    <div class="row mb-2">
        <div class="col-md-6">
            <a href="javascript:history.back()"
               class="btn btn-secondary">&larr; {{ 'admin.controls.back'|trans }}</a>
            <a href="{{ path('admin_crud_edit', {'entityClassName': entityClassName, 'entityId': entityId}) }}"
               class="btn btn-primary">{{ 'admin.controls.edit'|trans }}</a>
        </div>
        <div class="col-md-6 text-right">
            <a href="{{ path('admin_crud_delete', {'entityClassName': entityClassName, 'entityId': entityId}) }}"
               class="btn btn-danger"
               onClick="if(!confirm('{{ 'admin.confirm.are_you_sure'|trans }}?')){return false;}">{{ 'admin.controls.delete'|trans }}</a>
        </div>
    </div>
    <table class="table table-bordered table-hover table-striped">
        {% for item in data %}
            <tr>
                <td width="200"><b>{{ item.name|trans }}</b></td>
                <td>{{ item.value }}</td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}