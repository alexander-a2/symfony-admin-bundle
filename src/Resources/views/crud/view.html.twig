{% extends '@Admin/layout/dashboard.html.twig' %}

{% block main %}
    <div class="row mb-2">
        <div class="col-md-6">
            <a href="{{ path('admin_crud_index', {'objectClassName': objectClassName}) }}"
               class="btn btn-secondary">&larr; {{ 'Back'|translate }}</a>
            <a href="{{ path('admin_crud_edit', {'objectClassName': objectClassName, 'objectId': objectId}) }}"
               class="btn btn-primary">{{ 'Edit'|translate }}</a>
        </div>
        <div class="col-md-6 text-right">
            <a href="{{ path('admin_crud_delete', {'objectClassName': objectClassName, 'objectId': objectId}) }}"
               class="btn btn-danger" onClick="if(!confirm('Are you sure?')){return false;}">{{ 'Delete'|translate }}</a>
        </div>
    </div>
    <table class="table table-bordered table-hover table-striped">
        {% for item in data %}
            <tr>
                <td width="200"><b>{{ item.name|translate }}:</b></td>
                <td>{{ item.value }}</td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}